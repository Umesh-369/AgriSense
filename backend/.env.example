# Environment Variables for Smart Soil Moisture Backend
# Copy this file to .env and fill in your Firebase credentials

# Firebase Configuration
# Option 1: Path to your Firebase service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Option 2: Direct Firebase credentials (use either Option 1 or Option 2)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=your-client-email@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"

# Firebase Database URL
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com

# Server Configuration
PORT=3000

# Moisture Thresholds (percentage)
MOISTURE_LOW_THRESHOLD=30
MOISTURE_HIGH_THRESHOLD=70
